{
	"name": "dragonscript-language-client",
	"description": "VSCode part of a DragonScript Language Server",
	"publisher": "DragonDreams GmbH",
	"author": "DragonDreams GmbH",
	"license": "MIT",
	"version": "2.4.2",
	"repository": {
		"type": "git",
		"url": "https://github.com/LordOfDragons/vscode-langext-dragonscript"
	},
	"engines": {
		"vscode": "^1.63.0"
	},
	"dependencies": {
		"vscode-languageclient": "^7.0.0"
	},
	"devDependencies": {
		"@types/vscode": "^1.63.0",
		"@vscode/test-electron": "^2.5.2",
		"crc-32": "^1.2.2"
	},
	"scripts": {
		"prebuild": "rimraf ./out",
		"build": "npm run compile",
		"compile": "tsc",
		"dist-build": "npm run dist-compile",
		"dist-compile": "esbuild src/extension.ts --bundle --outfile=distribute/index.js --external:vscode --format=cjs --platform=node --minify --inject:./crc32-preload.js --external:crc-32 --external:@node-rs/*"
	}
}
